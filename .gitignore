##############################
# Node.js / Package managers  #
##############################
**/node_modules/

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

##############################
# Environment / Secrets       #
##############################
# Never commit secrets. Keep .env.example tracked instead.
.env
.env.*
.env.local
.env.*.local

# Common secret/key file names
*.pem
*.key
*.crt
*.p12
*.pfx

##############################
# Frontend build outputs      #
##############################
**/dist/
**/build/
**/.vite/

##############################
# Backend logs / runtime files #
##############################
logs/
*.log

##############################
# Coverage / test artifacts    #
##############################
coverage/
.nyc_output/

##############################
# Uploads / temp files         #
##############################
uploads/
temp/
.tmp/
*.tmp

##############################
# OS / System files            #
##############################
.DS_Store
Thumbs.db

##############################
# IDE / Editor files           #
##############################
.vscode/
.idea/
*.swp
*.swo

##############################
# Misc                         #
##############################
# Vercel/Netlify
.vercel/
.netlify/

# Local caches
.cache/
